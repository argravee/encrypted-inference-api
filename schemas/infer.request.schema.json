{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "model_id": { "type": "string" },
    "version": { "type": "string" },
    "batch_size": {
      "type": "integer",
      "minimum": 1
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "encoding": {
            "type": "string",
            "enum": ["hex"]
          },
          "payload": { "type": "string" }
        },
        "required": ["encoding", "payload"]
      }
    }
  },
  "required": ["model_id", "version", "batch_size", "inputs"]
}